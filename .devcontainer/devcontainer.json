{
  "name": "KubeQuest",
  "image": "mcr.microsoft.com/devcontainers/javascript-node:20-bookworm",
  "features": {
    "ghcr.io/devcontainers/features/docker-in-docker:2": {
      "moby": true,
      "dockerDashComposeVersion": "none"
    },
    "ghcr.io/devcontainers/features/kubectl-helm-minikube:1": {
      "version": "latest",
      "helm": "none",
      "minikube": "none"
    }
  },
  "forwardPorts": [3847, 16686, 9090],
  "portsAttributes": {
    "3847": {
      "label": "KubeQuest API / Live UI",
      "onAutoForward": "notify",
      "visibility": "public"
    },
    "16686": { "label": "Jaeger UI", "onAutoForward": "silent", "visibility": "private" },
    "9090": { "label": "Prometheus", "onAutoForward": "silent", "visibility": "private" }
  },
  "hostRequirements": {
    "cpus": 4,
    "memory": "8gb",
    "storage": "32gb"
  },
  "remoteEnv": {
    "GITHUB_REPOSITORY": "i-apologise/kubequest",
    "MIRROR_INTERVAL_MS": "15000"
  },
  "onCreateCommand": "bash .devcontainer/on-create.sh",
  "postStartCommand": "bash .devcontainer/post-start.sh",
  "customizations": {
    "vscode": {
      "settings": {
        "terminal.integrated.defaultProfile.linux": "bash"
      }
    },
    "codespaces": {
      "openFiles": ["README.md"]
    }
  },
  "remoteUser": "node",
  "postAttachCommand": "bash .devcontainer/motd.sh"
}
