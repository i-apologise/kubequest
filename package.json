{
  "name": "kubequest",
  "version": "1.1.0",
  "private": true,
  "description": "Learn Kubernetes by typing real kubectl commands with a live telemetry dashboard",
  "scripts": {
    "setup": "bash scripts/setup-cluster.sh && npm run build:telemetry",
    "reset": "bash scripts/reset-game.sh",
    "install:all": "npm ci && npm ci --prefix server && npm ci --prefix dashboard",
    "build:ui": "npm run build --prefix dashboard",
    "build:telemetry": "bash scripts/build-telemetry-image.sh",
    "dashboard": "node server/dashboard-server.mjs",
    "game": "node game.mjs",
    "start": "node game.mjs",
    "start:all": "concurrently -n game,ui -c cyan,magenta \"npm run game\" \"npm run dashboard\"",
    "start:ui": "npm run dashboard",
    "play": "node game.mjs",
    "play": "node game.mjs",
    "dev:ui": "npm run dev --prefix dashboard",
    "audit": "node scripts/e2e-audit.mjs"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  },
  "dependencies": {
    "chalk": "^4.1.2"
  }
}
